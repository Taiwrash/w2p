# W2P Environment Variables
# --------------------------
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and will NOT be committed.

# Gemini API key (required for AI-powered farm analysis and SMS translation)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend: Backend API base URL
# Leave empty ("") in Docker/production mode (same-origin, FastAPI serves static files).
# Set to http://localhost:8000 when running frontend and backend on separate processes (dev.sh mode).
VITE_API_URL=http://localhost:8000
